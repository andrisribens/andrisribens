# Copy to .env.local and fill in values.
# See AGENTS.md for details.

# Canonical site URL for Open Graph and other absolute metadata URLs
NEXT_PUBLIC_SITE_URL=https://andrisribens.com

# Met.no location forecast API — use /complete for full field set (no trailing ?)
NEXT_PUBLIC_WEATHER_API_URL=https://api.met.no/weatherapi/locationforecast/2.0/complete

# Nominatim search API (query params appended in code: city=… or q=…)
NEXT_PUBLIC_PLACE_API_URL=https://nominatim.openstreetmap.org/search?
